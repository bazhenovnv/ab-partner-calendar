generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERADMIN
}

enum EventFormat {
  ONLINE
  OFFLINE
  HYBRID
}

enum EventStatus {
  SCHEDULED
  LIVE
  COMPLETED
}

enum ImportStatus {
  NEW
  CONFIRMED
  REJECTED
  REVIEW
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  logs         AdminLog[]
}

model Category {
  id        String   @id @default(uuid())
  title     String   @unique
  slug      String   @unique
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Event {
  id               String      @id @default(uuid())
  title            String
  slug             String      @unique
  descriptionShort String
  descriptionFull  String
  startAt          DateTime
  endAt            DateTime
  location         String
  format           EventFormat
  imageUrl         String?
  source           String?
  sourceUrl        String?
  isImportant      Boolean     @default(false)
  status           EventStatus @default(SCHEDULED)
  published        Boolean     @default(true)
  tags             String[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  reminders        Reminder[]
}

model Reminder {
  id               String   @id @default(uuid())
  eventId          String
  telegramUserId   String
  telegramUsername String?
  remindBefore     String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, telegramUserId, remindBefore])
}

model TelegramImport {
  id                String       @id @default(uuid())
  sourcePostId      String       @unique
  sourceUrl         String
  rawText           String
  parsedTitle       String?
  parsedStartAt     DateTime?
  parsedLocation    String?
  parsedDescription String?
  status            ImportStatus @default(NEW)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model VisitHit {
  id          String   @id @default(uuid())
  anonId      String
  path        String   @default("/")
  city        String?
  source      String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([anonId])
  @@index([path])
}

model AdminLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
